    skos:broader <https://vocabs.dariah.eu/resource-type/service> ;
    skos:closeMatch <http://id.loc.gov/vocabulary/marcgt/web> ;
    skos:definition "\"A collection of related web pages containing text, images, videos and/or other digital assets that are addressed relative to a common Uniform Resource Locator (URL). A web site is hosted on at least one web server, accessible via a network such as the Internet or a private local area network. [Source: http://purl.org/spar/fabio/WebSite]\" (http://purl.org/coar/resource_type/c_7ad9)"@en ;
    skos:exactMatch <http://purl.org/coar/resource_type/c_7ad9> ;
    skos:prefLabel "website"@en .

