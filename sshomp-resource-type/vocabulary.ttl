<https://vocabs.dariah.eu/resource-type/gazetteer> a skos:Concept ;
    skos:broader <https://vocabs.dariah.eu/resource-type/dataset>,
        <https://vocabs.dariah.eu/resource-type/semantic-resource>,
        <https://vocabs.dariah.eu/resource-type/service> ;
    skos:definition """"Resources that function as geographical dictionaries or directories,
containing information about place names and their corresponding coordinates or
attributes. They support geospatial data management and enable the integration
of geographic information into digital systems." (Arıkan-Caba, C., Carloni, M., Charvát, V. M., Durco, M., & Felicetti, A. (2024). Overview of Models and Formats in the Field. Zenodo. https://doi.org/10.5281/zenodo.14575783, p.11) """@en ;
    skos:prefLabel "gazetteer"@en .

